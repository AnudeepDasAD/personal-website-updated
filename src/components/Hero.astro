---
import { profile } from '../data/cv';
---

<header id="top" class="hero">
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">{profile.eyebrow}</p>
      <h1>{profile.name}</h1>
      <p class="lede">
        I aim to build a safer <span class="erased">tomorrow</span> today with generative AI.
        My work critically examines the <strong>security and privacy</strong> of generative models,
        with the aim of accurately assessing their vulnerabilities,
        and developing methods to deploy them responsibly.
        My current focus is on concept removal techniques (CRTs) for image generative models,
        and LLM backdoors.
      </p>
      <div class="hero-meta">
        <span>PhD candidate, Computer Science</span>
        <span>Co-advised by Profs. N. Asokan &amp; Florian Kerschbaum</span>
        <a href={`mailto:${profile.email}`}>{profile.email}</a>
        <a href="/cvJuly2026.pdf" target="_blank" rel="noopener">CV ↗</a>
      </div>
    </div>
    <img class="hero-photo" src="/profile.png" alt={profile.name} width="367" height="537" />
  </div>
</header>

<style>
  .hero {
    padding: 5rem 0 3.5rem;
  }

  .hero-grid {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2.5rem;
  }

  .hero-copy {
    flex: 1;
    min-width: 0;
  }

  .hero-photo {
    flex: none;
    width: 9.5rem;
    height: 9.5rem;
    object-fit: cover;
    object-position: top center;
    border-radius: 1rem;
    border: 1px solid var(--line);
    animation: rise 0.6s ease both;
  }

  .eyebrow {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-ink);
    margin: 0 0 1.2rem;
    animation: rise 0.6s ease both;
  }

  h1 {
    font-size: clamp(2.6rem, 8vw, 3.9rem);
    line-height: 1.05;
    font-weight: 500;
    letter-spacing: -0.015em;
    margin: 0 0 1.5rem;
    text-wrap: balance;
    animation: rise 0.6s ease 0.1s both;
  }

  .lede {
    font-size: clamp(1.1rem, 2.5vw, 1.25rem);
    line-height: 1.6;
    color: var(--muted);
    max-width: 38rem;
    margin: 0 0 2rem;
    animation: rise 0.6s ease 0.2s both;
  }

  .lede strong {
    color: var(--ink);
    font-weight: 500;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.6rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
    animation: rise 0.6s ease 0.3s both;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* erasure motif — a strike that draws itself over the phrase */
  .erased {
    position: relative;
    white-space: nowrap;
    color: var(--ink);
  }

  .erased::after {
    content: '';
    position: absolute;
    left: -2px;
    right: -2px;
    top: 52%;
    height: 2px;
    background: var(--erase);
    transform: scaleX(0);
    transform-origin: left center;
    animation: strike 0.9s cubic-bezier(0.7, 0, 0.2, 1) 1.2s forwards;
  }

  @keyframes strike {
    to {
      transform: scaleX(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .eyebrow,
    h1,
    .lede,
    .hero-meta,
    .hero-photo {
      animation: none;
    }

    .erased::after {
      animation: none;
      transform: scaleX(1);
    }
  }

  @media (max-width: 40rem) {
    .hero {
      padding: 3.5rem 0 2.5rem;
    }

    .hero-grid {
      flex-direction: column-reverse;
      gap: 1.5rem;
    }

    .hero-photo {
      width: 6.5rem;
      height: 6.5rem;
    }

    .erased {
      white-space: normal;
    }
  }
</style>
