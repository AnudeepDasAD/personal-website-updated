---
const links = [
  { href: '#research', label: 'Research' },
  { href: '#publications', label: 'Publications' },
  { href: '#experience', label: 'Experience' },
  { href: '#awards', label: 'Awards' },
  { href: '#contact', label: 'Contact' },
];
---

<nav>
  <div class="wrap nav-inner">
    <a class="nav-name" href="#top">Anudeep Das</a>
    <div class="nav-links">
      {links.map(({ href, label }) => <a href={href}>{label}</a>)}
      <button id="theme-toggle" type="button" aria-label="Toggle light or dark theme">
        <span class="theme-icon" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--nav-bg);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
  }

  .nav-name {
    color: var(--ink);
    font-weight: 600;
    white-space: nowrap;
  }

  .nav-name:hover {
    text-decoration: none;
    color: var(--accent-ink);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .nav-links::-webkit-scrollbar {
    display: none;
  }

  .nav-links a {
    color: var(--muted);
    white-space: nowrap;
  }

  .nav-links a:hover {
    color: var(--accent-ink);
    text-decoration: none;
  }

  #theme-toggle {
    flex-shrink: 0;
    width: 1.9rem;
    height: 1.9rem;
    padding: 0;
    display: grid;
    place-items: center;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 50%;
    cursor: pointer;
    color: var(--muted);
  }

  #theme-toggle:hover {
    color: var(--accent-ink);
    border-color: var(--accent);
  }

  /* the icon: a half-filled circle that reads in both themes */
  .theme-icon {
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 50%;
    border: 1.5px solid currentColor;
    background: linear-gradient(90deg, currentColor 50%, transparent 50%);
  }

  @media (max-width: 40rem) {
    .nav-inner {
      gap: 0.75rem;
      padding: 0.8rem 1rem;
    }

    .nav-links {
      gap: 0.9rem;
    }
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const current = root.dataset.theme ?? (systemDark ? 'dark' : 'light');
    const next = current === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
